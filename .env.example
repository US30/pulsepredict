# =============================================================================
#  PulsePredict — Environment Variables
#  Copy to .env and fill in real values before running `make up`.
#  Never commit .env to version control.
# =============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulsepredict
POSTGRES_USER=pulsepredict
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://pulsepredict:changeme@localhost:5432/pulsepredict

# ── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO (S3-compatible object store) ─────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pulsepredict-data

# ── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Kaggle API (required for M5 Competition dataset download) ───────────────
# Get your credentials at https://www.kaggle.com/settings/account → API
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Hugging Face Hub (Chronos-T5 foundation model weights cache) ────────────
HF_HUB_CACHE=/tmp/hf_cache

# ── Compute ─────────────────────────────────────────────────────────────────
# Set to "cpu" if no GPU is available, or "cuda:0" to target a specific GPU
DEVICE=cuda

# ── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Error tracking (optional — leave blank to disable) ─────────────────────
SENTRY_DSN=
